
import java.io.*;
import java.nio.ByteBuffer;
import java.nio.ByteOrder;
import java.nio.file.*;
import java.util.*;

public class zip {

    // ── constants ─────────────────────────────────────────────────────
    static final int   DecompressionChecker = 0x5A503200;
    static final short RawMarker            = (short) 0xFFFF;
    static final long  Maxfilesz            = 4_000_000_000L;
    static final int   MaxFilter            = 4196;

    // ── ZipHeader ─────────────────────────────────────────────────────
    static class ZipHeader {
        int   DecompressionChecker;
        int   origSize;
        short dictSize;

        static final int SIZE = 10;

        byte[] toBytes() {
            return ByteBuffer.allocate(SIZE)
                .order(ByteOrder.LITTLE_ENDIAN)
                .putInt(DecompressionChecker)
                .putInt(origSize)
                .putShort(dictSize)
                .array();
        }

        static ZipHeader fromBytes(byte[] b) {
            ByteBuffer buf = ByteBuffer.wrap(b).order(ByteOrder.LITTLE_ENDIAN);
            ZipHeader h = new ZipHeader();
            h.DecompressionChecker = buf.getInt();
            h.origSize             = buf.getInt();
            h.dictSize             = buf.getShort();
            return h;
        }
    }

    
    static byte[] readfile(String path) throws IOException {
        File f = new File(path);
        if (!f.exists()) {
            System.out.println("Error: file not found → " + path);
            return null;
        }
        if (f.length() > Maxfilesz) {
            System.out.println("Error: file is too large to compress (max 4 GB) → " + path);
            return null;
        }
        return Files.readAllBytes(f.toPath());
    }

    
    static HashMap<Integer, Integer> countBlocks(byte[] contents) {
        HashMap<Integer, Integer> freq = new HashMap<>();
        ByteBuffer buf = ByteBuffer.wrap(contents).order(ByteOrder.LITTLE_ENDIAN);
        while (buf.remaining() >= 4) {
          int key = buf.getInt();
            freq.put(key, freq.getOrDefault(key, 0) + 1);
        }
        return freq;
    }

    static void sortByFrequencyBubble(List<Map.Entry<Integer, Integer>> entries) {
    for (int i = 0; i < entries.size() - 1; i++) {
        for (int j = 0; j < entries.size() - i - 1; j++) {
            if (entries.get(j).getValue() < entries.get(j + 1).getValue()) {
                Map.Entry<Integer, Integer> temp = entries.get(j);
                entries.set(j, entries.get(j + 1));
                entries.set(j + 1, temp);
            }
        }
    }
    }


    static List<Integer> buildDictionary(HashMap<Integer, Integer> freq) {
        List<Map.Entry<Integer, Integer>> entries = new ArrayList<>(freq.entrySet());
        sortByFrequencyBubble(entries);

        List<Integer> dict = new ArrayList<>();
        for (int i = 0; i < Math.min(MaxFilter, entries.size()); i++)
            dict.add(entries.get(i).getKey());
        return dict;
    }


    static void encode(byte[] contents, List<Integer> dict, String outPath)
            throws IOException {

        HashMap<Integer, Integer> dictIndex = new HashMap<>();
        for (int i = 0; i < dict.size(); i++)
            dictIndex.put(dict.get(i), i);

        ZipHeader hdr = new ZipHeader();
        hdr.DecompressionChecker = DecompressionChecker;
        hdr.origSize             = contents.length;
        hdr.dictSize             = (short) dict.size();

        ByteBuffer entry = ByteBuffer.allocate(6).order(ByteOrder.LITTLE_ENDIAN);

        try (DataOutputStream out = new DataOutputStream(
                new BufferedOutputStream(new FileOutputStream(outPath)))) {

            out.write(hdr.toBytes());

            // write dictionary
            for (int block : dict) {
                entry.clear();
                out.write(entry.putInt(block).array(), 0, 4);
            }

            int tokens = 0, saved = 0;
            ByteBuffer src = ByteBuffer.wrap(contents).order(ByteOrder.LITTLE_ENDIAN);

            while (src.remaining() >= 4) {
                int block = src.getInt();
                Integer idx = dictIndex.get(block);
                entry.clear();

                if (idx != null) {
                    out.write(entry.putShort((short)(int) idx).array(), 0, 2);
                    saved += 2;
                } else {
                    entry.putShort(RawMarker).putInt(block);
                    out.write(entry.array(), 0, 6);
                    saved -= 2;
                }
                tokens++;
            }

            System.out.println("Encoded: " + tokens + " blocks, saved " + saved + " bytes");
            System.out.println("Original: " + contents.length + " bytes  →  Compressed: ~" +
                (ZipHeader.SIZE + dict.size() * 4 + tokens * 2) + " bytes");

        } catch (IOException e) {
            System.out.println("Error: failed to write compressed file → " + outPath);
        }
    }

    // ── DECODE ────────────────────────────────────────────────────────
    static void decode(String inPath, String outPath) throws IOException {
        byte[] compressed = Files.readAllBytes(Paths.get(inPath));

        if (compressed.length < ZipHeader.SIZE) {
            System.out.println("Error: file is too small to be a valid .zp2 archive → " + inPath);
            return;
        }

        ZipHeader hdr = ZipHeader.fromBytes(compressed);
        if (hdr.DecompressionChecker != DecompressionChecker) {
            System.out.println("Error: file is not a valid .zp2 archive (bad magic number) → " + inPath);
            return;
        }

        System.out.println("Decoding: original size=" + hdr.origSize + "  dictionary size=" + hdr.dictSize);

        int    dictSize = hdr.dictSize & 0xFFFF;
        int[]  dict     = new int[dictSize];
        ByteBuffer src  = ByteBuffer.wrap(compressed).order(ByteOrder.LITTLE_ENDIAN);
        src.position(ZipHeader.SIZE);

        for (int i = 0; i < dictSize; i++)
            dict[i] = src.getInt();

        ByteBuffer out = ByteBuffer.allocate(hdr.origSize + 4).order(ByteOrder.LITTLE_ENDIAN);

        while (src.remaining() >= 2 && out.position() < hdr.origSize) {
            short token = src.getShort();

            if (token == RawMarker) {
                out.putInt(src.getInt());
            } else {
                int idx = token & 0xFFFF;
                if (idx >= dictSize) {
                    System.out.println("Error: archive is corrupt — dictionary index " + idx +
                        " is out of range (dict size=" + dictSize + ")");
                    return;
                }
                out.putInt(dict[idx]);
            }
        }

        Files.write(Paths.get(outPath), Arrays.copyOf(out.array(), hdr.origSize));
        System.out.println("Decoded: " + hdr.origSize + " bytes → " + outPath);
    }

    // ── main ──────────────────────────────────────────────────────────
public static void main(String[] args) throws IOException {

    Scanner scanner = new Scanner(System.in);
    System.out.print("Enter file path: ");
    String inPath = scanner.nextLine().trim();
    scanner.close();

    if (inPath.isEmpty()) {
        System.out.println("Error: no file path entered");
        return;
    }

    String compPath   = inPath + ".zp2";
    String decompPath = inPath;

    byte[] contents = readfile(inPath);
    if (contents == null) return;

    System.out.println("Original size: " + contents.length + " bytes");

    HashMap<Integer, Integer> freq = countBlocks(contents);
    List<Integer> dict = buildDictionary(freq);
    encode(contents, dict, compPath);

    System.out.println("Compressed size: " + new File(compPath).length() + " bytes");

    decode(compPath, decompPath);

    byte[] restored = Files.readAllBytes(Paths.get(decompPath));
    System.out.println("Decompressed size: " + new File(decompPath).length() + " bytes");
    System.out.println(restored.length == contents.length ? "contents equal" : "contents differ");
    System.out.println("Size of Restored File: " + restored.length);
    System.out.println("Size of Original File: " + contents.length);
}
}
